// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider = "prisma-client"
  output   = "../app/generated/prisma"
}

datasource db {
  provider = "sqlite"
}

model House {
  id            String   @id @default(cuid())
  address       String
  addressDetail String?
  buildYear     Int?
  area          Float?
  houseType     String
  ownerName     String?
  notes         String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  inventories   Inventory[]
  histories     History[]
  sortOrder       Int      @default(0)
  utilities       Utility[]
  doctorHistories DoctorHistory[]
  valuation       Valuation?
}


model Inventory {
  id             String    @id @default(cuid())
  houseId        String
  house          House     @relation(fields: [houseId], references: [id], onDelete: Cascade)
  category       String
  name           String
  brand          String?
  model          String?
  installedAt    DateTime?
  warrantyMonths Int?
  notes          String?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt
}

model Valuation {
  id               String   @id @default(cuid())
  houseId          String   @unique
  house            House    @relation(fields: [houseId], references: [id], onDelete: Cascade)
  // 토지 (단독/빌라/다가구)
  landPrice        Int?     // 개별공시지가 (원/㎡)
  landArea         Float?   // 대지면적 (㎡)
  landShare        Float?   // 지분율 (예: 0.5 = 50%)
  // 건물
  buildCostPerSqm  Int?     // 건축비 단가 (원/㎡)
  buildArea        Float?   // 연면적 (㎡)
  deprRate         Float?   // 연 감가율 (기본 0.02)
  // 아파트 공동주택 공시가격
  officialPrice    Int?     // 공동주택 공시가격 (원)
  priceRatio       Float?   // 공시가격 반영률 (기본 0.7)
  updatedAt        DateTime @updatedAt
  createdAt        DateTime @default(now())
}

model DoctorHistory {
  id          String   @id @default(cuid())
  houseId     String
  house       House    @relation(fields: [houseId], references: [id], onDelete: Cascade)
  description String?
  imageBase64 String?
  result      String
  createdAt   DateTime @default(now())
}

model Utility {
  id        String   @id @default(cuid())
  houseId   String
  house     House    @relation(fields: [houseId], references: [id], onDelete: Cascade)
  month     String   // "2026-06" 형식
  electric  Int?     // 전기세
  water     Int?     // 수도세
  gas       Int?     // 가스비
  telecom   Int?     // 통신비
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([houseId, month])
}

model History {
  id          String   @id @default(cuid())
  houseId     String
  house       House    @relation(fields: [houseId], references: [id], onDelete: Cascade)
  category    String
  title       String
  description String?
  company     String?
  cost        Int?
  doneAt      DateTime
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}
