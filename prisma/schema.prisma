// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider = "prisma-client"
  output   = "../app/generated/prisma"
}

datasource db {
  provider = "sqlite"
}

model House {
  id            String   @id @default(cuid())
  address       String
  addressDetail String?
  buildYear     Int?
  area          Float?
  houseType     String
  ownerName     String?
  notes         String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  inventories   Inventory[]
  histories     History[]
  utilities      Utility[]
  doctorHistories DoctorHistory[]
}


model Inventory {
  id             String    @id @default(cuid())
  houseId        String
  house          House     @relation(fields: [houseId], references: [id], onDelete: Cascade)
  category       String
  name           String
  brand          String?
  model          String?
  installedAt    DateTime?
  warrantyMonths Int?
  notes          String?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt
}

model DoctorHistory {
  id          String   @id @default(cuid())
  houseId     String
  house       House    @relation(fields: [houseId], references: [id], onDelete: Cascade)
  description String?
  imageBase64 String?
  result      String
  createdAt   DateTime @default(now())
}

model Utility {
  id        String   @id @default(cuid())
  houseId   String
  house     House    @relation(fields: [houseId], references: [id], onDelete: Cascade)
  month     String   // "2026-06" 형식
  electric  Int?     // 전기세
  water     Int?     // 수도세
  gas       Int?     // 가스비
  telecom   Int?     // 통신비
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([houseId, month])
}

model History {
  id          String   @id @default(cuid())
  houseId     String
  house       House    @relation(fields: [houseId], references: [id], onDelete: Cascade)
  category    String
  title       String
  description String?
  company     String?
  cost        Int?
  doneAt      DateTime
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}
