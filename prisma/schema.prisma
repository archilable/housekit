// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider = "prisma-client"
  output   = "../app/generated/prisma"
}

datasource db {
  provider = "sqlite"
}

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String?   @unique
  emailVerified DateTime?
  image         String?
  accounts      Account[]
  sessions      Session[]
  houses        House[]
  houseAccess   HouseAccess[]
  isAdmin       Boolean   @default(false)
  createdAt     DateTime  @default(now())
}

model HouseInvite {
  id        String   @id @default(cuid())
  houseId   String
  house     House    @relation(fields: [houseId], references: [id], onDelete: Cascade)
  token     String   @unique @default(cuid())
  createdAt DateTime @default(now())
}

model HouseAccess {
  id        String   @id @default(cuid())
  houseId   String
  house     House    @relation(fields: [houseId], references: [id], onDelete: Cascade)
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())

  @@unique([houseId, userId])
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime
  @@unique([identifier, token])
}

model House {
  id            String   @id @default(cuid())
  userId        String?
  user          User?    @relation(fields: [userId], references: [id], onDelete: Cascade)
  address       String
  addressDetail String?
  buildYear     Int?
  area          Float?
  landArea      Float?
  buildArea     Float?
  exclusiveArea Float?
  houseType     String
  ownerName     String?
  notes         String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  inventories   Inventory[]
  histories     History[]
  sortOrder       Int      @default(0)
  utilities       Utility[]
  doctorHistories DoctorHistory[]
  valuation       Valuation?
  invites         HouseInvite[]
  accessList      HouseAccess[]
}


model Inventory {
  id             String    @id @default(cuid())
  houseId        String
  house          House     @relation(fields: [houseId], references: [id], onDelete: Cascade)
  category       String
  name           String
  brand          String?
  model          String?
  installedAt    DateTime?
  warrantyMonths Int?
  notes          String?
  sortOrder           Int       @default(0)
  contactName         String?
  contactPhone        String?
  contactCompany      String?
  contactImageBase64  String?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt
}

model Valuation {
  id               String   @id @default(cuid())
  houseId          String   @unique
  house            House    @relation(fields: [houseId], references: [id], onDelete: Cascade)
  // 토지 (단독/빌라/다가구)
  landPrice        Int?     // 개별공시지가 (원/㎡)
  landArea         Float?   // 대지면적 (㎡)
  landShare        Float?   // 지분율 (예: 0.5 = 50%)
  // 건물
  buildCostPerSqm  Int?     // 건축비 단가 (원/㎡)
  buildArea        Float?   // 연면적 (㎡)
  deprRate         Float?   // 연 감가율 (기본 0.02)
  // 아파트 공동주택 공시가격
  officialPrice    Int?     // 공동주택 공시가격 (원)
  priceRatio       Float?   // 공시가격 반영률 (기본 0.7)
  updatedAt        DateTime @updatedAt
  createdAt        DateTime @default(now())
}

model DoctorHistory {
  id          String    @id @default(cuid())
  houseId     String
  house       House     @relation(fields: [houseId], references: [id], onDelete: Cascade)
  description String?
  imageBase64 String?
  result      String
  resolved    Boolean   @default(false)
  resolvedAt  DateTime?
  createdAt   DateTime  @default(now())
}

model Utility {
  id        String   @id @default(cuid())
  houseId   String
  house     House    @relation(fields: [houseId], references: [id], onDelete: Cascade)
  month     String   // "2026-06" 형식
  electric  Int?     // 전기세
  water     Int?     // 수도세
  gas       Int?     // 가스비
  telecom   Int?     // 통신비
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([houseId, month])
}

model History {
  id                   String   @id @default(cuid())
  houseId              String
  house                House    @relation(fields: [houseId], references: [id], onDelete: Cascade)
  category             String
  title                String
  description          String?
  company              String?
  cost                 Int?
  doneAt               DateTime
  contactName          String?
  contactPhone         String?
  contactCompany       String?
  contactImageBase64   String?
  contractImageBase64  String?
  estimateImageBase64  String?
  createdAt            DateTime @default(now())
  updatedAt            DateTime @updatedAt
}
